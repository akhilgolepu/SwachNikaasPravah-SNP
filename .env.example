# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000

# ── Backend ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./drainage.db

# Path to YOLO model weights. Default: YOLOv8n pre-trained on COCO.
# Replace with your custom drain-detection model:
# YOLO_MODEL_PATH=path/to/your/custom_drain_model.pt
YOLO_MODEL_PATH=yolov8n.pt
